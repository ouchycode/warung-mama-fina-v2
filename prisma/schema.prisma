generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id        String   @id @default(uuid())
  name      String
  price     Int
  stock     Int      @default(0)
  image     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id              String   @id
  customerName    String
  customerPhone   String
  totalAmount     Int
  status          String   @default("pending")
  items           Json
  paymentMethod   String?  // opsional (midtrans nanti)
  paymentStatus   String?  // opsional
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}